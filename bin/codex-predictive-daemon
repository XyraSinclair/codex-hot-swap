#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import subprocess
import sys
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(HERE))

from codex_hot_swap_lib import (  # noqa: E402
    account_states,
    codex_home,
    live_tabs,
    load_config,
    pick_account,
    quota_walled_emails,
    run_usage_refresh_if_enabled,
    write_json_atomic,
    write_quota_wall_cache,
)


def maybe_switch_default(home: Path, config: dict, states) -> bool:
    if not config.get("switch_default", False):
        return False
    if live_tabs(home):
        return False
    walled = quota_walled_emails(home, config)
    target = pick_account(states, config, walled=walled)
    if target is None:
        return False
    env = dict(os.environ)
    env["CODEX_HOME"] = str(home)
    try:
        subprocess.run(
            ["codex-auth", "switch", target.email],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            env=env,
            timeout=60,
            check=False,
        )
        return True
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


def tick(home: Path, once: bool = False) -> None:
    config = load_config(home)
    refreshed = run_usage_refresh_if_enabled(home, config)
    states = account_states(home, config)
    walls = write_quota_wall_cache(home, states)
    switched = maybe_switch_default(home, config, states)
    write_json_atomic(
        home / "predictive_state.json",
        {
            "written_at": time.time(),
            "once": once,
            "usage_refresh_attempted": bool(config.get("refresh_codex_auth_usage")),
            "usage_refreshed": refreshed,
            "global_switch_attempted": bool(config.get("switch_default", False)),
            "global_switch_performed": switched,
            "account_count": len(states),
            "wall_count": len(walls.get("accounts", {})),
            "live_tab_count": len(live_tabs(home)),
        },
    )


def main() -> int:
    parser = argparse.ArgumentParser(description="Maintain Codex Hot Swap cached state")
    parser.add_argument("--once", action="store_true", help="run one polling tick and exit")
    args = parser.parse_args()

    home = codex_home()
    if args.once:
        tick(home, once=True)
        return 0

    while True:
        config = load_config(home)
        tick(home)
        time.sleep(max(5, int(config.get("poll_interval_seconds", 60))))


if __name__ == "__main__":
    raise SystemExit(main())
