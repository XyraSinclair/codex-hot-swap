#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import subprocess
import sys
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(HERE))

from codex_hot_swap_lib import (  # noqa: E402
    account_states,
    codex_home,
    live_tabs,
    load_json,
    load_config,
    pick_account,
    quota_walled_emails,
    run_usage_refresh_if_enabled,
    write_json_atomic,
    write_quota_wall_cache,
)


def maybe_switch_default(home: Path, config: dict, states) -> dict:
    if not config.get("switch_default", False):
        return {"performed": False, "reason": "disabled", "target": None}
    if live_tabs(home):
        return {"performed": False, "reason": "live-tabs", "target": None}
    walled = quota_walled_emails(home, config)
    target = pick_account(states, config, walled=walled)
    if target is None:
        return {"performed": False, "reason": "no-usable-account", "target": None}

    previous = load_json(home / "predictive_state.json", {})
    previous_email = None
    if isinstance(previous, dict):
        previous_email = previous.get("selected_default_email")
    if isinstance(previous_email, str) and previous_email.lower() != target.email.lower():
        current = next(
            (state for state in states if state.email.lower() == previous_email.lower()),
            None,
        )
        tolerance = float(config.get("load_balance_tolerance_pct", 15) or 0)
        if (
            current is not None
            and current.auth_exists
            and not current.broken
            and current.email.lower() not in walled
            and target.usable_remaining - current.usable_remaining < tolerance
        ):
            return {
                "performed": False,
                "reason": "within-tolerance",
                "target": current.email,
                "candidate": target.email,
            }

    env = dict(os.environ)
    env["CODEX_HOME"] = str(home)
    try:
        result = subprocess.run(
            ["codex-auth", "switch", target.email],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            env=env,
            timeout=60,
            check=False,
        )
        if result.returncode == 0:
            return {"performed": True, "reason": "switched", "target": target.email}
        return {
            "performed": False,
            "reason": f"codex-auth-exit-{result.returncode}",
            "target": target.email,
        }
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return {"performed": False, "reason": "codex-auth-unavailable", "target": target.email}


def tick(home: Path, once: bool = False) -> None:
    config = load_config(home)
    refreshed = run_usage_refresh_if_enabled(home, config)
    states = account_states(home, config)
    walls = write_quota_wall_cache(home, states)
    switch = maybe_switch_default(home, config, states)
    write_json_atomic(
        home / "predictive_state.json",
        {
            "written_at": time.time(),
            "once": once,
            "usage_refresh_attempted": bool(config.get("refresh_codex_auth_usage")),
            "usage_refreshed": refreshed,
            "global_switch_attempted": bool(config.get("switch_default", False)),
            "global_switch_performed": bool(switch.get("performed")),
            "global_switch_reason": switch.get("reason"),
            "selected_default_email": switch.get("target"),
            "candidate_default_email": switch.get("candidate"),
            "account_count": len(states),
            "wall_count": len(walls.get("accounts", {})),
            "live_tab_count": len(live_tabs(home)),
        },
    )


def main() -> int:
    parser = argparse.ArgumentParser(description="Maintain Codex Hot Swap cached state")
    parser.add_argument("--once", action="store_true", help="run one polling tick and exit")
    args = parser.parse_args()

    home = codex_home()
    if args.once:
        tick(home, once=True)
        return 0

    while True:
        config = load_config(home)
        tick(home)
        time.sleep(max(5, int(config.get("poll_interval_seconds", 60))))


if __name__ == "__main__":
    raise SystemExit(main())
