#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(HERE))

from codex_hot_swap_lib import codex_home, live_tabs, load_config, write_json_atomic  # noqa: E402


SMOOTH_UPDATES = {
    "refresh_codex_auth_usage": True,
    "poll_interval_seconds": 30,
    "quota_wall_max_age_seconds": 120,
    "live_migrate_below_5h_percent": 2,
    "live_migrate_below_weekly_percent": 2,
    "live_migrate_idle_seconds": 2,
}


def main() -> int:
    parser = argparse.ArgumentParser(description="Configure Codex Hot Swap smooth mode")
    parser.add_argument("--enable", action="store_true")
    parser.add_argument("--disable", action="store_true")
    parser.add_argument("--allow-live", action="store_true")
    args = parser.parse_args()

    if args.enable == args.disable:
        parser.error("choose exactly one of --enable or --disable")

    home = codex_home()
    path = home / "codex-hotswap.json"
    config = load_config(home)

    if args.enable:
        tabs = live_tabs(home)
        if tabs and not args.allow_live:
            print(
                "Refusing to enable smooth mode while live tabs exist. "
                "Use --allow-live only after accepting the polling/migration risk.",
                file=sys.stderr,
            )
            return 2
        config.update(SMOOTH_UPDATES)
    else:
        config["refresh_codex_auth_usage"] = False
        config["live_migrate_below_5h_percent"] = 0
        config["live_migrate_below_weekly_percent"] = 0

    write_json_atomic(path, config)
    print(f"updated {path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
